# CookieCloud 服务地址（公开实例或自建）
COOKIECLOUD_URL=https://ccc.ft07.com
# CookieCloud 扩展里配置的 UUID
COOKIECLOUD_UUID=your-uuid-here
# CookieCloud 扩展里配置的密码
COOKIECLOUD_PASSWORD=your-password-here

# CF Worker 部署后的 URL（wrangler deploy 之后获得）
CF_WORKER_URL=https://cookiecloud-cf-scraper.xxx.workers.dev

# ═══ CloakBrowser 本地模式（可选） ═══
# CDP 端口 — 从本地 Edge 直接提取 Cookie，无需 CookieCloud
# 启动 Edge: msedge --remote-debugging-port=9222
# CDP_PORT=9222
# 默认代理，命令行 --proxy 优先级更高
# CLOAK_PROXY=socks5://user:pass@proxy:1080
# 默认持久化用户目录
# CLOAK_PROFILE=./browser-profiles/default
